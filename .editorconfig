# EditorConfig - https://editorconfig.org
# Root config: stop searching for .editorconfig files in parent directories.
root = true

# Default settings for all files.
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Python files.
# Matches the project's ruff line-length = 120 setting.
[*.py]
indent_style = space
indent_size = 4

# TOML files (pyproject.toml and similar).
[*.toml]
indent_style = space
indent_size = 4

# Markdown files.
# Trailing whitespace is significant in Markdown (line breaks).
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# HTML files.
[*.html]
indent_style = space
indent_size = 2

# CSS files.
[*.css]
indent_style = space
indent_size = 2

# JSON files.
[*.json]
indent_style = space
indent_size = 2

# YAML files.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Git attributes and similar dotfiles.
[.gitattributes]
indent_style = space
indent_size = 4

# Batch files on Windows.
[*.bat]
end_of_line = crlf

# Windows shell scripts.
[*.cmd]
end_of_line = crlf